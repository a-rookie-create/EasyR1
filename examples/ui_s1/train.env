# Version-controlled UI-S1 experiment definition. Command-line environment
# variables may override any value for an explicitly recorded experiment.
DATASET="${DATASET:-android_control}"
EPOCHS="${EPOCHS:-5}"
MAX_STEPS="${MAX_STEPS:-}"
ROLLOUT_BATCH_SIZE="${ROLLOUT_BATCH_SIZE:-3}"
ACTOR_GLOBAL_BATCH_SIZE="${ACTOR_GLOBAL_BATCH_SIZE:-3}"
# GRPO needs at least two trajectories per task. Four keeps a useful
# within-task comparison while avoiding the previous eight-way default.
ROLLOUT_N="${ROLLOUT_N:-4}"
ACTOR_DYNAMIC_BATCHING="${ACTOR_DYNAMIC_BATCHING:-false}"
ACTOR_USE_TORCH_COMPILE="${ACTOR_USE_TORCH_COMPILE:-false}"
EXPERIENCE_MICRO_BATCH_SIZE="${EXPERIENCE_MICRO_BATCH_SIZE:-1}"
# The 210 server runs four independent TP=1 vLLM workers. Four distinct
# rollout-step requests therefore give every GPU useful work in one wave. Set
# a larger value only after confirming vLLM has enough KV-cache memory; set 0
# to explicitly generate every active trajectory in one vLLM request.
GENERATION_MICRO_BATCH_SIZE="${GENERATION_MICRO_BATCH_SIZE:-4}"
# Bound diversity retries. It must remain at least ROLLOUT_N.
MAX_ROLLOUTS_PER_TASK="${MAX_ROLLOUTS_PER_TASK:-8}"
HISTORY_IMAGE_LIMIT="${HISTORY_IMAGE_LIMIT:-2}"
MAX_PROMPT_LENGTH="${MAX_PROMPT_LENGTH:-12288}"
MAX_RESPONSE_LENGTH="${MAX_RESPONSE_LENGTH:-512}"
MAX_IMAGE_PIXELS="${MAX_IMAGE_PIXELS:-2097152}"
VLLM_MAX_MODEL_LEN="${VLLM_MAX_MODEL_LEN:-12800}"
VLLM_MAX_NUM_BATCHED_TOKENS="${VLLM_MAX_NUM_BATCHED_TOKENS:-24576}"
LORA_TARGET_MODULES="${LORA_TARGET_MODULES:-q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj}"
PATCH_THRESHOLD="${PATCH_THRESHOLD:-1}"
UIS1_GAMMA="${UIS1_GAMMA:-0.5}"
UIS1_STEP_ADVANTAGE_WEIGHT="${UIS1_STEP_ADVANTAGE_WEIGHT:-1.0}"
UIS1_EPISODE_ADVANTAGE_WEIGHT="${UIS1_EPISODE_ADVANTAGE_WEIGHT:-1.0}"
UIS1_ADVANTAGE_STD_THRESHOLD="${UIS1_ADVANTAGE_STD_THRESHOLD:-0.3}"
SAVE_EVERY_N_EPOCHS="${SAVE_EVERY_N_EPOCHS:-1}"
