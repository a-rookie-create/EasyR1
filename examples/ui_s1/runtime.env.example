# Copy this file to runtime.env and change PROJECT_ROOT for each server.
# runtime.env is machine-specific and intentionally ignored by Git.
PROJECT_ROOT="${PROJECT_ROOT:-/path/to/biye210}"

MODEL_PATH="${MODEL_PATH:-${PROJECT_ROOT}/llamafactory/output/ui_s1_qwen25vl_3b_android_control_amex_lora_full_3gpu_merged}"
TOKENIZER_PATH="${TOKENIZER_PATH:-${PROJECT_ROOT}/models/qwen2.5-vl/Qwen2.5-VL-3B-Instruct}"
OUTPUT_ROOT="${OUTPUT_ROOT:-${PROJECT_ROOT}/EasyR1/output}"

AMEX_DIR="${AMEX_DIR:-${PROJECT_ROOT}/datasets/amex}"
AMEX_OUTPUT_DIR="${AMEX_OUTPUT_DIR:-${PROJECT_ROOT}/EasyR1/datasets/ui_s1_amex_rl}"
ANDROID_CONTROL_DIR="${ANDROID_CONTROL_DIR:-${PROJECT_ROOT}/datasets/android_control}"
ANDROID_CONTROL_IMAGE_DIR="${ANDROID_CONTROL_IMAGE_DIR:-${PROJECT_ROOT}/llamafactory/data/ui_s1_android_control_sft/images}"
ANDROID_CONTROL_OUTPUT_DIR="${ANDROID_CONTROL_OUTPUT_DIR:-${PROJECT_ROOT}/EasyR1/datasets/ui_s1_android_control_rl}"

# Adjust these values to the GPUs and network policy of this server.
GPU_IDS="${GPU_IDS:-${CUDA_VISIBLE_DEVICES:-0,2}}"
RAY_DASHBOARD_HOST="${RAY_DASHBOARD_HOST:-0.0.0.0}"
VLLM_GPU_MEMORY_UTILIZATION="${VLLM_GPU_MEMORY_UTILIZATION:-0.62}"
PYTORCH_CUDA_ALLOC_CONF="${PYTORCH_CUDA_ALLOC_CONF:-expandable_segments:True}"
